<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Same dark palette as the default theme; the app is dark in both modes. -->
    <style name="Theme.NetworkAnalyzer" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/accent_download</item>
        <item name="colorPrimaryVariant">@color/accent_download</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_upload</item>
        <item name="colorSecondaryVariant">@color/accent_upload</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>
</resources>
